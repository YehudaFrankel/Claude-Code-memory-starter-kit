{
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep"
    ],
    "deny": []
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python tools/check_memory.py --silent"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python tools/session_journal.py",
            "timeout": 10,
            "statusMessage": "Capturing session journal..."
          },
          {
            "type": "command",
            "command": "python tools/stop_check.py",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
